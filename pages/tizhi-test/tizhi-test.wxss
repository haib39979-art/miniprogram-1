.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f7f7f7;
  padding: 0;
}

.header {
  padding: 40rpx 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
}

.question-list {
  flex: 1;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.question-item {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.q-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
  line-height: 1.5;
}

.options {
  display: flex;
  justify-content: space-between;
}

.option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  margin: 0 10rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option.selected {
  background: #e6f7ff;
  border-color: #1890ff;
  color: #1890ff;
  font-weight: 500;
}

.footer-btn {
  padding: 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.submit-btn {
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.submit-btn[disabled] {
  background: #a0e6c0;
  color: #fff;
}

/* Result Styles */
.result-container {
  padding: 40rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.08);
  margin-bottom: 60rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 50rpx;
}

.result-label {
  display: block;
  font-size: 28rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.result-type {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #333;
}

.result-section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 8rpx;
  height: 32rpx;
  background: #07c160;
  border-radius: 4rpx;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: justify;
}

.finish-btn {
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  width: 100%;
  font-weight: bold;
}